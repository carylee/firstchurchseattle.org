{
    "name": "firstchurch/stock-photos",
    "description": "Find attribution-safe, openly-licensed photos from Openverse and pull them into the media library, with provenance.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload-dev": {
        "psr-4": {
            "FirstChurch\\StockPhotos\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "tests/bootstrap.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
