# First Church Seattle — single repo.
#
# This repo tracks ONLY our custom code + ops/docs (Class A in ops/sync/ownership.md).
# Everything else here is a local MIRROR of production (WordPress core, uploads, third-party
# plugins/themes, the DB, prod subdirs), refreshed by `ddev pull-prod` and never committed.
# The rules below are the inverse of the ownership table: ignore all, then re-include ours.

# 1) Ignore everything by default.
/*

# 2) Repo meta + docs + ops tooling + DDEV config + CI/CD.
!/.gitignore
!/README.md
!/CLAUDE.md
!/ops/
!/.ddev/
# but never the local secrets / personal overrides under .ddev/
/.ddev/.env
/.ddev/.env.*
/.ddev/config.local.yaml
!/.github/

# 3) Local-only artifacts (DB dumps).
/db/

# 3b) Workspace datasets — generated by ../datasets/ and checked in here so they
# travel with the repo (enews, hymns, breeze forms, transcripts, worship corpus,
# bible). Git-only: not in ops/deploy.sh, so they never ship to prod. Refresh via
# `cd ../datasets && uv run build.py && uv run distribute.py`.
!/data/
/data/*
!/data/church/

# 4) Custom webroot code (track only our file in bulletin/).
!/bulletin/
/bulletin/*
!/bulletin/index.php

# 5) WordPress: re-include only our custom code under wp-content/.
!/wp-content/
/wp-content/*
!/wp-content/themes/
/wp-content/themes/*
# firstchurch: our standalone theme. (The old maranatha parent + maranatha-child
# pair was retired in 2026 — any maranatha dirs are mirrored prod leftovers
# until deleted there, and are ignored like other third-party themes.)
!/wp-content/themes/firstchurch/
# ...but never its Tailwind build artifacts. assets/tailwind.css is a BUILT file
# (source of truth: assets/src/input.css) — NOT committed. CD compiles it on the
# runner and ships it; locally, `ddev pull-prod` rsyncs prod's copy down (or run
# ./build-css.sh when editing styles). node_modules is likewise generated.
/wp-content/themes/firstchurch/node_modules/
/wp-content/themes/firstchurch/assets/tailwind.css
!/wp-content/plugins/
/wp-content/plugins/*
!/wp-content/plugins/firstchurch-connection-card/
!/wp-content/plugins/firstchurch-breeze-forms/
!/wp-content/plugins/firstchurch-carousel/
!/wp-content/plugins/firstchurch-happenings/
!/wp-content/plugins/firstchurch-events/
!/wp-content/plugins/firstchurch-people/
!/wp-content/plugins/firstchurch-stock-photos/
!/wp-content/plugins/firstchurch-enews/
!/wp-content/plugins/firstchurch-comms-desk/
!/wp-content/plugins/firstchurch-bulletin-publish/
!/wp-content/mu-plugins/
/wp-content/mu-plugins/*
!/wp-content/mu-plugins/firstchurch-mcp-abilities.php
# Ability modules required by the loader above (WP doesn't auto-load mu-plugin
# subdirs). The whole subdir is ours and ships to prod — track all of it.
!/wp-content/mu-plugins/firstchurch-mcp-abilities/
!/wp-content/mu-plugins/sso.php
!/wp-content/mu-plugins/firstchurch-google-register-policy.php
!/wp-content/mu-plugins/firstchurch-google-login-callback.php
!/wp-content/mu-plugins/firstchurch-security-headers.php
# Test harness for the MCP mu-plugin (dev-only; not deployed). Track the source,
# but not the Composer/PHPUnit build artifacts.
!/wp-content/mu-plugins/firstchurch-mcp/
/wp-content/mu-plugins/firstchurch-mcp/vendor/
/wp-content/mu-plugins/firstchurch-mcp/.phpunit.cache/
# uploads/ is a prod mirror (gitignored), but we DO ship ONE file: an .htaccess
# adding CORS headers to upload images so the slides editor can fetch them to bake
# the announcement carousel GIF (Apache serves uploads statically — can't be a
# PHP hook). Track only that file; never the mirrored image library.
!/wp-content/uploads/
/wp-content/uploads/*
!/wp-content/uploads/.htaccess

# Never commit these, even inside tracked dirs (later rules win).
wp-config.php
wp-config-ddev.php
*.log
.DS_Store

# Dev-only build artifacts inside our plugins (Composer deps, PHPUnit cache).
/wp-content/plugins/*/vendor/
/wp-content/plugins/*/.phpunit.cache/

# Dev-only JS toolchain artifacts in the theme (Node modules, test output).
# The committed source (assets/js/, tests/, e2e/, *.config.js) IS tracked; these
# generated dirs are not. They're also excluded from deploy in ops/deploy.sh.
/wp-content/themes/firstchurch/node_modules/
/wp-content/themes/firstchurch/playwright-report/
/wp-content/themes/firstchurch/test-results/
/wp-content/themes/firstchurch/coverage/
